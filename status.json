{
    "config": {
      "servo": {
        // Servo PWM calibration values — must match SERVO_MIN/MID/MAX_US #define
        "minUs": 1820,      // full left steering
        "neutralUs": 2040,  // center (straight)
        "maxUs": 2260       // full right steering
      },
      "esc": {
        // ESC PWM calibration values — must match ESC_MIN/MID/MAX_US #define
        "minUs": 1430,      // full forward
        "neutralUs": 1495,  // neutral (stop)
        "maxUs": 1560       // full reverse
      }
    },
    "telemetry": {
      "sonar": {
        "lCm": 36.4,        // left sonar: raw distance (hypotenuse), cm
        "rCm": 66.4,        // right sonar: raw distance (hypotenuse), cm
        "lLv": 2,           // left proximity level (1=critical ... 5=clear)
        "rLv": 3,           // right proximity level (1=critical ... 5=clear)
        // Proximity levels are computed from thresholds below — changeable via POST /set-prox
        "lFwd": 31.5,       // left sensor forward component (lCm × cos α), cm
        "lLat": 18.2,       // left sensor lateral component (lCm × sin α), cm
        "rFwd": 57.5,       // right sensor forward component (rCm × cos α), cm
        "rLat": 33.2,       // right sensor lateral component (rCm × sin α), cm
        "angle": 30.0,      // sensor mount angle, degrees
        "thresholds": {
          // Active threshold values — changeable at runtime via POST /set-prox (DISARMED + MANUAL only)
          "close": 20,      // <= this → emergency stop + full steer away (sonarCloseCm)
          "lv1": 35,        // <= this → Level 1, critical danger (proxLv1)
          "lv2": 60,        // <= this → Level 2, close (proxLv2)
          "lv3": 85,        // <= this → Level 3, moderate (proxLv3)
          "lv4": 115        // <= this → Level 4, safe approach (proxLv4)
        }
      },
      "lidar": {
        "ok": true,         // TF-Luna UART data arriving
        "cm": 70,           // TF-Luna measured distance, cm (-1 = invalid/error)
        "thresholds": {
          // Active threshold values — changeable at runtime via POST /set-lidar (DISARMED + MANUAL only)
          "stop": 50,       // <= this → EMERGENCY (lidarStopCm)
          "slow": 100       // <= this → reduced speed; above this → full speed (lidarSlowCm)
        }
      },
      "imu": {
        "ok": false,        // MPU6050 init successful
        "calibrated": false,// gyro calibration complete (waits ~1.2s at startup, 300 samples)
        "ax": null,         // acceleration X, g
        "ay": null,         // acceleration Y, g
        "az": null,         // acceleration Z, g  (≈ +1g on flat ground)
        "gx": null,         // angular velocity X, deg/s
        "gy": null,         // angular velocity Y, deg/s
        "gz": null,         // angular velocity Z, deg/s
        "roll": null,       // complementary filter output, deg (right side down = positive)
        "pitch": null,      // complementary filter output, deg (nose up = positive)
        "yaw": null,        // complementary filter output, deg (clockwise = positive)
        "temp": null        // MPU6050 internal temperature, °C
      },
      "odometry": {
        // Dead-reckoning — encoder + IMU integration (Phase 4+)
        "x": null,          // position X, m
        "y": null           // position Y, m
      },
      "control": {
        "steer": null,      // computed steering angle, degrees
        "steerPct": 0,      // steering percentage (-100...+100)
        "servoUs": 2040,    // microseconds written to servo (starts at neutralUs)
        "thrPct": 50,       // throttle percentage (0...100)
        "escUs": 1495       // microseconds written to ESC (starts at neutralUs)
      },
      "battery": {
        // Battery ADC — measured via voltage divider (Phase 3+; CONFIRM: measure actual VDIV_RATIO)
        "v": null,          // battery voltage, V
        "pct": null         // battery charge percentage, 0-100
      },
      "system": {
        "mstate": "DISARMED",          // ARM state: DISARMED | ARMED | EMERGENCY
        "armPct": 0,                   // arming progress % (currently 0 or 100)
        "disarmReason": "web_manual",  // last disarm reason: none | btn_manual | web_manual | emergency_stop | wall_detected
        "mode": "MANUAL",              // drive mode: MANUAL | AUTO
        "auto-mode-enabled": false,    // AUTO mode active
        "auto-mode-status": "single-car", // auto version: single-car | multi-car
        "emergency": false             // emergency flag
      },
      "wireless": {
        "wifiOk": true,     // WiFi connected
        "rssi": -42         // WiFi signal strength, dBm (>= -70 = usable)
      },
      "limits": {
        // Runtime limit values — changeable via POST /set
        "throttleLimit": 100, // throttle limit % (100 = full ESC range)
        "autoThrottle": 20    // auto mode fixed throttle % (reserved, not yet used)
      }
    }
  }
